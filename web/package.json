    "test:e2e:prod": "cross-env E2E_MODE=deployed PLAYWRIGHT_BASE_URL=https://estate-transaction-system.vercel.app PLAYWRIGHT_API_BASE_URL=https://estate-transaction-api.onrender.com playwright test"
  },
  "dependencies": {
    "@nuxtjs/tailwindcss": "^6.14.0",
