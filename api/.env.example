NODE_ENV=development
HOST=0.0.0.0
PORT=3000

# Comma-separated list of allowed frontend origins for CORS.
# Local development defaults are also allowed automatically when NODE_ENV is not production.
FRONTEND_ORIGIN=http://127.0.0.1:3001,http://localhost:3001

# Optional. Leave empty to keep routes as /agents and /transactions.
# Set to api if you want routes like /api/agents and /api/transactions.
API_PREFIX=

# Local default, used when MONGODB_URI is not set in development.
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DATABASE=estate_transaction_system

# Production example:
# NODE_ENV=production
# HOST=0.0.0.0
# PORT=3000
# FRONTEND_ORIGIN=https://estate-transaction-system.vercel.app/
# API_PREFIX=
# MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-host>/<database>?retryWrites=true&w=majority
# MONGODB_DATABASE=estate_transaction_system
